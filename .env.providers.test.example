# 自检脚本读取本文件。复制为 .env.providers.test 后按需填 key。
# 留空的 provider 会自动 skip，不会报错。
# 可选：覆盖 default 探测模型，写 <ID>_MODEL=xxx

# === LKEAP · Token Plan ===
# LKEAP_PLAN_KEY=
# LKEAP_PLAN_MODEL=glm-5.1

# === LKEAP · 按量 ===
# LKEAP_STD_KEY=
# LKEAP_STD_MODEL=deepseek-v3

# === DeepSeek 官方 ===
# DEEPSEEK_KEY=
# DEEPSEEK_MODEL=deepseek-chat

# === 阿里 DashScope ===
# DASHSCOPE_KEY=
# DASHSCOPE_MODEL=qwen-turbo

# === 智谱 GLM ===
# ZHIPU_KEY=
# ZHIPU_MODEL=glm-4-air

# === Moonshot Kimi ===
# MOONSHOT_KEY=
# MOONSHOT_MODEL=moonshot-v1-32k

# === 字节豆包 ===
# DOUBAO_KEY=
# DOUBAO_MODEL=<必填 endpoint id>

# === 硅基流动 ===
# SILICONFLOW_KEY=
# SILICONFLOW_MODEL=Qwen/Qwen2.5-7B-Instruct

# === OpenRouter ===
# OPENROUTER_KEY=
# OPENROUTER_MODEL=deepseek/deepseek-chat-v3

# === Ollama 本地 ===
# OLLAMA_KEY=
# OLLAMA_MODEL=qwen2.5:14b

# === OpenAI ===
# OPENAI_KEY=
# OPENAI_MODEL=gpt-4o-mini

# === xAI Grok ===
# GROK_KEY=
# GROK_MODEL=grok-3-mini
