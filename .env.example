# 用户自带 API Key，OpenAI 兼容协议即可。任选其一。

# === 腾讯云 LKEAP Token Plan（推荐，包月套餐）===
LLM_BASE_URL=https://api.lkeap.cloud.tencent.com/plan/v3
LLM_API_KEY=sk-tp-xxx
LLM_MODEL=glm-5.1
# Token Plan 全是思考型模型，要给足
LLM_MAX_TOKENS=4096

# 可选模型（Token Plan）：
#   minimax-m2.7  /  minimax-m2.5
#   glm-5.1       /  glm-5
#   kimi-k2.5
#   tc-code-latest（Auto 智能路由）

